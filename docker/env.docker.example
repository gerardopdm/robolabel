# Copia este archivo a la raíz del repositorio como `.env.docker` o ejecuta:
#   ./scripts/docker-setup.sh
#
# Docker Compose usa este archivo para interpolación de variables:
#   docker compose --env-file .env.docker ...

# --- Obligatorio en contenedores (el script docker-setup.sh lo rellena) ---
DJANGO_SECRET_KEY=cambia-esto-en-produccion
DJANGO_DEBUG=0
USE_WHITENOISE=1

# Hosts permitidos (coma, sin espacios). Incluye el dominio o IP desde la que accedes al navegador.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,nginx,backend

# Puerto publicado para la UI (mapeo nginx)
HTTP_PORT=80

# --- Motor: sqlite | postgresql | mysql ---
DJANGO_DATABASE=sqlite

# SQLite (ruta dentro del volumen montado en backend)
SQLITE_PATH=/data/db.sqlite3

# PostgreSQL (solo si DJANGO_DATABASE=postgresql y perfil compose --profile postgres)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=robolabel
POSTGRES_PASSWORD=robolabel
POSTGRES_DB=robolabel

# MySQL (solo si DJANGO_DATABASE=mysql y perfil --profile mysql)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=robolabel
MYSQL_PASSWORD=robolabel
MYSQL_DATABASE=robolabel

# Perfil de Compose usado por scripts/docker-up.sh (postgres | mysql | vacío para SQLite)
ROBOLABEL_COMPOSE_PROFILE=
